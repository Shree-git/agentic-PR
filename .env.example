# Required for real Composio execution. Leave unset for mock demo mode.
COMPOSIO_API_KEY=
COMPOSIO_USER_ID=hackathon-demo-user
COMPOSIO_WEBHOOK_SECRET=

# Optional. Enables LLM-generated patch plans before the catalog fallback.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=deepseek/deepseek-v4-pro
OPENROUTER_PROVIDER_ONLY=

# Optional. The app defaults to mock mode when COMPOSIO_API_KEY is missing.
COMPOSIO_MODE=mock

# Optional. Used by generated artifact URLs in mock mode.
DEMO_GITHUB_OWNER=demo-org
DEMO_GITHUB_REPO=incident-fixtures
DEMO_GITHUB_BASE=main
DEMO_SLACK_CHANNEL=incident-response
DEMO_LINEAR_TEAM=ENG
DEMO_LINEAR_TEAM_ID=
DEMO_LINEAR_PROJECT_ID=
DEMO_LINEAR_ASSIGNEE_ID=
DEMO_LINEAR_STATE_ID=
DEMO_SHEET_ID=demo-sheet
DEMO_SHEET_NAME=Sheet1

# Optional Composio tool slug overrides.
TOOL_LINEAR_ISSUE=LINEAR_CREATE_LINEAR_ISSUE
TOOL_GITHUB_COMMIT=GITHUB_COMMIT_MULTIPLE_FILES
TOOL_GITHUB_PR=GITHUB_CREATE_A_PULL_REQUEST
TOOL_SLACK_UPDATE=SLACK_SEND_MESSAGE
TOOL_SHEETS_AUDIT=GOOGLESHEETS_UPSERT_ROWS
